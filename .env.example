# BFAI + Gunita Configuration
# Copy this file to .env and adjust values as needed.
# The .env file is auto-loaded by pydantic-settings on startup.

# ── Vault ────────────────────────────────────────────────────────────────
# Path to the markdown vault directory (default: ./vault)
BFAI_VAULT_PATH=./vault

# Database path (optional). Falls back to <vault>/metadata/bfai.db
# BFAI_DB_PATH=

# ── Embedding Provider ───────────────────────────────────────────────────
# One of: sentence-transformers (default), ollama, openai
BFAI_EMBEDDING_PROVIDER=sentence-transformers

# Model name (provider-specific default if not set):
#   ollama               → nomic-embed-text
#   openai               → text-embedding-3-small
#   sentence-transformers → all-MiniLM-L6-v2
# Can also be a local path to a downloaded sentence-transformers model:
#   e.g. BFAI_EMBEDDING_MODEL=./models/models--sentence-transformers--all-MiniLM-L6-v2/snapshots/<snapshot-hash>
# BFAI_EMBEDDING_MODEL=nomic-embed-text

BFAI_EMBEDDING_BATCH_SIZE=32
BFAI_EMBEDDING_DIMENSIONS=768

# ── API Keys / URLs ──────────────────────────────────────────────────────
# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI API key (only used when provider is "openai")
# OPENAI_API_KEY=sk-...

# ── Sync ─────────────────────────────────────────────────────────────────
BFAI_SYNC_INTERVAL=60
BFAI_SYNC_BATCH_SIZE=50
BFAI_SYNC_MAX_WORKERS=4

# ── Chunking ─────────────────────────────────────────────────────────────
BFAI_CHUNK_SIZE=500
BFAI_CHUNK_OVERLAP=50
BFAI_CHUNK_BY_LINES=true

# ── Qdrant Vector Database ───────────────────────────────────────────────
# URL of the Qdrant server (default: http://localhost:6333)
# BFAI_QDRANT_URL=http://localhost:6333
# BFAI_QDRANT_COLLECTION=bfai

# ── Gunita Server ────────────────────────────────────────────────────────
GUNITA_HOST=0.0.0.0
GUNITA_PORT=8080
GUNITA_RELOAD=false
GUNITA_GRAPH_MAX_NODES=100
# GUNITA_API_KEY=optional-secret-key

# Comma-separated list of extra vault paths (optional)
# GUNITA_EXTRA_VAULTS=/path/to/vault2,/path/to/vault3